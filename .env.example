APP_NAME="Imagina Reports"
APP_ENV=local
APP_KEY=
APP_VERSION=1.0.0
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Database: MariaDB (production). Tests use the in-memory sqlite connection (phpunit.xml). ---
DB_CONNECTION=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=imagina_reports
DB_USERNAME=root
DB_PASSWORD=

# --- Redis-backed queue / cache / sessions (CLAUDE.md §2). ---
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Horizon dashboard prefix.
HORIZON_PREFIX=imagina_reports_horizon

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- Sanctum: stateful domains for the first-party SPAs (admin + portal). ---
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1,127.0.0.1:8000

# --- AI report builder via the Claude API (CLAUDE.md §10.6). Phase 2. ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Self-updater (CLAUDE.md §12). Phase 2. ---
UPDATER_CHANNEL=stable
UPDATER_SOURCE=imagina-updater

# --- Browsershot (Puppeteer) for PDF rendering (CLAUDE.md §10.7). ---
# Use a REAL (non-snap) Chrome/Chromium binary. Browsershot needs the full `puppeteer`
# package (install with PUPPETEER_SKIP_DOWNLOAD=true so it uses this Chrome, not its own).
BROWSERSHOT_CHROME_PATH=/usr/bin/google-chrome-stable
# Node runtime + puppeteer location on the VPS (assets are still built in CI).
BROWSERSHOT_NODE_PATH=/usr/bin/node
# BROWSERSHOT_NPM_PATH=/usr/bin/npm
# Absolute path to a node_modules dir that contains `puppeteer`, e.g. the shared dir:
# BROWSERSHOT_NODE_MODULE_PATH=/home/user/imagina-reports/shared/node_modules

VITE_APP_NAME="${APP_NAME}"
